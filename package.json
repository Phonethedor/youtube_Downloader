{
  "name": "youtube_downloader",
  "version": "1.0.0",
  "description": "Youtube video downloader desktop app",
  "keywords": [
    "ELECTRON",
    "JS",
    "NODE",
    "DESKTOP",
    "YOUTUBE"
  ],
  "license": "ISC",
  "author": "Alvaro Castillo",
  "type": "commonjs",
  "main": "src/main/main.js",
  "homepage": ".",
  "scripts": {
    "start": "electron .",
    "dev": "set NODE_ENV=development && electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:dir": "electron-builder --dir",
    "dist": "npm run build",
    "pack": "electron-builder --dir"
  },
  "build": {
    "appId": "com.alvarocastillo.youtube-downloader",
    "productName": "YouTube Downloader",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "node_modules/bootstrap/dist/",
        "to": "bootstrap/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "requestedExecutionLevel": "asInvoker",
      "artifactName": "${productName}-${version}-Setup.${ext}",
      "forceCodeSigning": false,
      "verifyUpdateCodeSignature": false,
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "YouTube Downloader",
      "uninstallDisplayName": "YouTube Downloader",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    },
    "portable": {
      "artifactName": "YouTube-Downloader-Portable-${version}.exe"
    }
  },
  "devDependencies": {
    "electron": "^37.2.2",
    "electron-builder": "^26.0.12"
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.1.11",
    "bootstrap": "^5.3.3",
    "ffmpeg-static": "^5.3.0",
    "node-fetch": "^3.3.2",
    "youtube-dl-exec": "^3.1.3",
    "youtube-po-token-generator": "^0.6.0"
  }
}
